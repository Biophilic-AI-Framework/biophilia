# ── Required ─────────────────────────────────────────────────────────────────
# HMAC key used by BiophilicActionInterface to authorise physical actuator calls.
# Must be set before starting the application; any non-empty value is accepted.
BIF_SECRET_KEY=change-me-before-production

# ── Optional ─────────────────────────────────────────────────────────────────
# Absolute path to a custom network-baseline JSON.
# Omit to use the bundled default (src/biophilia/_data/biophilic_baseline.json).
# BIF_BASELINE_PATH=/path/to/custom/biophilic_baseline.json

# Directory where the pulse log and integrity chronicle are written.
# Omit to use ./logs relative to the working directory.
# BIF_LOG_DIR=/var/log/biophilia

# Pump control endpoint (used by BiophilicActionInterface).
# BIF_PUMP_API_URL=http://localhost/pump

